# Database
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus?sslmode=disable

# Server
PORT=8080
APP_ENV=development
ALLOWED_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=dev-secret-change-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis (for asynq worker queue)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# LLM Provider: claude-cli | claude-api | gemini
LLM_PROVIDER=claude-cli
LLM_MODEL=

# Claude CLI
MCP_CONFIG_PATH=backend/mcp-config.json
CLAUDE_CLI_PATH=claude

# Claude API
ANTHROPIC_API_KEY=

# Gemini API
GEMINI_API_KEY=
